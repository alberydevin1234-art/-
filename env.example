import { useState, useEffect } from 'react';
import { Shield, Clock, Flame, ShieldAlert, Wifi, Sliders } from 'lucide-react';

interface HeaderProps {
  activeTab: string;
  setActiveTab: (tab: string) => void;
  serverName: string;
  setServerName: (name: string) => void;
  commanderName: string;
  setCommanderName: (name: string) => void;
  onClearData: () => void;
}

export default function Header({
  activeTab,
  setActiveTab,
  serverName,
  setServerName,
  commanderName,
  setCommanderName,
  onClearData
}: HeaderProps) {
  const [time, setTime] = useState(new Date());
  const [showConfig, setShowConfig] = useState(false);

  useEffect(() => {
    const timer = setInterval(() => setTime(new Date()), 1000);
    return () => clearInterval(timer);
  }, []);

  const formattedTime = time.toLocaleTimeString('ru-RU');
  const formattedDate = time.toLocaleDateString('ru-RU', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });

  return (
    <header className="border-b border-slate-900 bg-slate-950/60 backdrop-blur-xl sticky top-0 z-40">
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
          
          {/* Unit Branding Container */}
          <div className="flex items-center gap-4">
            <div className="w-12 h-12 bg-red-600/15 border border-red-500/30 rounded-xl flex items-center justify-center text-red-500 shadow-lg shadow-red-950/20 relative overflow-hidden group">
              <span className="absolute inset-0 bg-red-500/5 animate-pulse" />
              <Shield className="w-6 h-6 text-red-500 relative z-10 group-hover:scale-110 transition" />
            </div>
            
            <div>
              <div className="flex items-center gap-2">
                <span className="bg-red-950/40 text-red-400 border border-red-500/25 px-2 py-0.5 rounded text-[9px] font-bold font-mono uppercase tracking-wider">
                  ОСН «Берсерк»
                </span>
                <span className="inline-flex items-center gap-1 text-[9px] font-mono text-slate-400">
                  <Wifi className="w-2.5 h-2.5 text-emerald-400 animate-pulse" />
                  ONLINE • TITAN
                </span>
              </div>
              <h1 className="text-xl font-black font-sans text-white tracking-widest uppercase mt-0.5">
                ОСН <span className="text-red-500">«БЕРСЕРК»</span>
              </h1>
              <p className="text-[10px] text-slate-500 font-mono mt-0.5 uppercase tracking-wide">
                amazing-online • спецотряд быстрого реагирования • {serverName}
              </p>
            </div>
          </div>

          {/* Active Navigation Tabs */}
          <div className="flex items-center p-1 bg-slate-900/50 border border-slate-850 rounded-xl">
            <button
              onClick={() => setActiveTab('members')}
              className={`py-1.5 px-3 rounded-lg text-xs font-semibold tracking-wide transition-all ${
                activeTab === 'members' 
                  ? 'bg-red-650 text-white shadow-sm shadow-red-950/50' 
                  : 'text-slate-400 hover:text-white'
              }`}
            >
              База Бойцов
            </button>
            <button
              onClick={() => setActiveTab('operations')}
              className={`py-1.5 px-3 rounded-lg text-xs font-semibold tracking-wide transition-all ${
                activeTab === 'operations' 
                  ? 'bg-red-650 text-white shadow-sm shadow-red-950/50' 
                  : 'text-slate-400 hover:text-white'
              }`}
            >
              Спецоперации
            </button>
            <button
              onClick={() => setActiveTab('calculator')}
              className={`py-1.5 px-3 rounded-lg text-xs font-semibold tracking-wide transition-all ${
                activeTab === 'calculator' 
                  ? 'bg-red-650 text-white shadow-sm shadow-red-950/50' 
                  : 'text-slate-400 hover:text-white'
              }`}
            >
              Калькулятор Отчетов
            </button>
          </div>

          {/* Military HUD Time and Config Trigger */}
          <div className="flex items-center gap-4 text-right">
            <div className="hidden sm:block">
              <div className="flex items-center justify-end gap-1.5 text-xs font-bold text-white font-mono">
                <Clock className="w-3.5 h-3.5 text-slate-400" />
                <span>{formattedTime} UTC</span>
              </div>
              <p className="text-[10px] text-slate-500 uppercase tracking-widest mt-0.5">
                {formattedDate}
              </p>
            </div>

            <button
              onClick={() => setShowConfig(!showConfig)}
              className="p-2 bg-slate-900 hover:bg-slate-800 text-slate-400 hover:text-white border border-slate-800 rounded-lg transition"
              title="Настройки штаба"
            >
              <Sliders className="w-4 h-4 text-orange-500" />
            </button>
          </div>

        </div>

        {/* Tactical Config Panel Slide */}
        {showConfig && (
          <div className="mt-4 p-5 bg-slate-950 border border-slate-900/80 rounded-xl grid grid-cols-1 md:grid-cols-3 gap-4 items-end animate-fadeIn">
            <div>
              <label className="block text-[10px] font-mono text-slate-400 uppercase tracking-wide mb-1.5">
                Задать сервер Amazing Online
              </label>
              <input
                type="text"
                className="w-full px-3 py-2 bg-slate-950 border border-slate-800 rounded-lg text-xs text-white focus:outline-none focus:border-red-500/50 transition font-mono"
                value={serverName}
                onChange={(e) => setServerName(e.target.value)}
              />
            </div>

            <div>
              <label className="block text-[10px] font-mono text-slate-400 uppercase tracking-wide mb-1.5">
                Командир Подразделения
              </label>
              <input
                type="text"
                className="w-full px-3 py-2 bg-slate-950 border border-slate-800 rounded-lg text-xs text-white focus:outline-none focus:border-red-500/50 transition font-mono"
                value={commanderName}
                onChange={(e) => setCommanderName(e.target.value)}
              />
            </div>

            <div className="flex gap-2">
              <button
                onClick={() => {
                  if (confirm('Вы уверены, что хотите сбросить все изменения базы данных к исходным?')) {
                    onClearData();
                  }
                }}
                className="flex-1 py-2 px-3 bg-red-950/20 hover:bg-red-900/30 text-red-400 hover:text-red-300 border border-red-900/30 rounded-lg text-xs font-semibold transition"
              >
                Сбросить БД состава
              </button>
              
              <button
                onClick={() => setShowConfig(false)}
                className="py-2 px-4 bg-slate-900 hover:bg-slate-800 text-slate-300 rounded-lg text-xs font-semibold border border-slate-800 transition"
              >
                ОК
              </button>
            </div>
          </div>
        )}

      </div>
    </header>
  );
}
